    Xe_shap = X_test_scaled.sample(sample_size, random_state=42)
else:
    Xe_shap = X_test.sample(sample_size, random_state=42)

# choose explainer based on model type
if isinstance(best_model, (lgb.LGBMClassifier, xgb.XGBClassifier, RandomForestClassifier)):
    explainer = shap.TreeExplainer(best_model)
    shap_values = explainer.shap_values(Xe_shap)

    if isinstance(shap_values, list):
        shap_values = shap_values[1]  # class 1

elif isinstance(best_model, LogisticRegression):
    bg_size = min(1000, len(X_train_scaled))
    background = X_train_scaled.sample(bg_size, random_state=42)

    explainer = shap.LinearExplainer(best_model, background)
    shap_values = explainer.shap_values(Xe_shap)

else:
    raise ValueError(f"Unsupported model type for SHAP: {type(best_model)}")

